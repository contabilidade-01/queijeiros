# Copiar para .env na raiz (não commitar o .env real).
# No Easypanel: definir as mesmas chaves nas variáveis de ambiente do serviço Compose.
#
# Login administrador (platform_admins): CPF 05487541523 | senha inicial padrão: 35736034000123
# (é o CNPJ seed "Gestão Empresa", não o CPF). Empresas: login CNPJ, senha = 14 dígitos do CNPJ.

# Obrigatório em produção — mesma palavra-passe para Postgres e API (utilizador rhapp).
# Se mudares depois do primeiro deploy, ver db/fix-rhapp-password.sql
DB_PASSWORD=defina_uma_senha_forte

# Obrigatório em produção — string longa e aleatória (ex.: openssl rand -hex 32)
JWT_SECRET=defina_um_segredo_jwt_longo

# Obrigatório em hospedagem só com front estático (ex.: preview Lovable): URL completo da API Node, com /api no fim.
# Se ficar vazio, o browser chama /api no MESMO domínio do site — em previews sem backend isso devolve HTML e o login falha.
# Ex.: https://api.teudominio.com/api
VITE_API_URL=

# Só desenvolvimento (Vite): para onde encaminhar /api (API Node local). Opcional.
# VITE_PROXY_API_TARGET=http://127.0.0.1:3001

# Recuperação de senha (API): URL pública do front, ex. https://app.seudominio.com (sem / no fim)
PUBLIC_APP_URL=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
