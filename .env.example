# Copiar para .env na raiz (não commitar o .env real).
# No Easypanel: definir as mesmas chaves nas variáveis de ambiente do serviço Compose.

# Obrigatório em produção — mesma palavra-passe para Postgres e API
DB_PASSWORD=defina_uma_senha_forte

# Obrigatório em produção — string longa e aleatória (ex.: openssl rand -hex 32)
JWT_SECRET=defina_um_segredo_jwt_longo

# Opcional: deixe vazio se o Nginx do contentor frontend faz proxy de /api para a API.
# Preencha só se o front for buildado para chamar outra URL (outro domínio).
# Ex.: https://app.gestaoempresa.com/api ou https://api.teudominio.com/api
VITE_API_URL=
